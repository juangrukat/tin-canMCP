# Copy this file to .env and adjust values for your deployment.

# ----- Catalog runtime -----
# Absolute path to the catalog-runtime directory (must contain registry/*.json).
# Leave blank to use the repo-local ./catalog-runtime
# VAR_CATALOG_RUNTIME_DIR=

# MCP server identity shown to clients.
VAR_SERVER_NAME=tin-canMCP

# Per-tool execution timeout (seconds).
VAR_COMMAND_TIMEOUT_SECONDS=20

# Truncation threshold for tool stdout/stderr (chars).
VAR_MAX_OUTPUT_CHARS=12000

# ----- Optional API settings (only if your catalog tools need them) -----
VAR_API_KEY=
VAR_API_BASE_URL=

# ----- Transport -----
# stdio | sse | web (alias for sse)
MCP_TRANSPORT=stdio
